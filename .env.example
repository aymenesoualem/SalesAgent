# Copy this file to .env and fill in real values. Never commit .env.

# --- Server ---
PORT=8080

# --- Azure AI Foundry / Azure OpenAI Realtime API ---
# Used by agents/agent.py to power the voice customer support agent (speech-to-speech).
# Resource endpoint from your Foundry/Azure OpenAI resource, e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com
# One of the resource's API keys (Keys and Endpoint blade in the Azure/Foundry portal)
AZURE_OPENAI_API_KEY=
# Name of your realtime model deployment (e.g. gpt-4o-realtime-preview), not the base model name
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-realtime-preview
# Realtime API version to target
AZURE_OPENAI_API_VERSION=2024-10-01-preview
# Voice for spoken responses: alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin, cedar.
# marin/cedar are the newest, most natural-sounding voices (gpt-realtime model family).
AZURE_REALTIME_VOICE=marin
# Turn detection (when the model decides the caller finished talking): server_vad or semantic_vad.
AZURE_REALTIME_TURN_DETECTION=server_vad
# server_vad tuning (ignored for semantic_vad):
AZURE_REALTIME_VAD_THRESHOLD=0.5
AZURE_REALTIME_VAD_PREFIX_PADDING_MS=300
AZURE_REALTIME_VAD_SILENCE_MS=500
# semantic_vad tuning (ignored for server_vad): low, medium, high, or auto
AZURE_REALTIME_VAD_EAGERNESS=auto

# --- Twilio (inbound calls + SMS confirmations) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Tavily (product search on histoiredor.com) ---
TAVILY_API_KEY=

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://agent:sales@localhost:5432/ThomGroupSupport_db

# --- SIP trunk ---
# Credentials from your SIP trunk provider (e.g. Manivox). Used by agents/sip_agent.py
# to register directly to the trunk's hosted Janus Gateway and handle inbound calls,
# instead of Twilio.
SIP_SERVER=
SIP_LOGIN=
SIP_PASSWORD=
SIP_SDA=
SIP_WEBRTC_URL=
# Optional overrides — agents/sip_agent.py has working defaults for Manivox.
SIP_JANUS_WS_URL=
SIP_DOMAIN=
SIP_TURN_HOST=
SIP_TURN_USERNAME=
SIP_TURN_CREDENTIAL=

